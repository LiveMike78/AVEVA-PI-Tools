    <AFAnalysisTemplate>
      <Name>Shift Times</Name>
      <Description>Use periodic scheduling to align execution with shift start/end times</Description>
      <OutputTime />
      <GroupID>0</GroupID>
      <CaseTemplate />
      <Target>Shift Pattern (Daily) Schedule</Target>
      <CreateEnabled>false</CreateEnabled>
      <AFAnalysisRule>
        <AFPlugIn>PerformanceEquation</AFPlugIn>
        <ConfigString>NoShift := // System digital state used to indicate out of hours&#xD;
DigState("Out of Serv");&#xD;
Now := '*';&#xD;
Sunday := // Is the shift active today (Sunday)&#xD;
'Shifts|Sunday' And Weekday(Now) = 1;&#xD;
Monday := // Is the shift active today (Monday)&#xD;
'Shifts|Monday' And Weekday(Now) = 2;&#xD;
Tuesday := // Is the shift active today (Tuesday)&#xD;
'Shifts|Tuesday' And Weekday(Now) = 3;&#xD;
Wednesday := // Is the shift active today (Wednesday)&#xD;
'Shifts|Wednesday' And Weekday(Now) = 4;&#xD;
Thursday := // Is the shift active today (Thursday)&#xD;
'Shifts|Thursday' And Weekday(Now) = 5;&#xD;
Friday := // Is the shift active today (Friday)&#xD;
'Shifts|Friday' And Weekday(Now) = 6;&#xD;
Saturday := // Is the shift active today (Saturday)&#xD;
'Shifts|Saturday' And Weekday(Now) = 7;&#xD;
ABORT1 := // If there is no shift activity today abort &#xD;
If Sunday or Monday Or Tuesday Or Wednesday Or Thursday Or Friday or Saturday Then "Continue" Else Exit();&#xD;
ShiftSchedule := // Get the shift schedule&#xD;
'Shifts';&#xD;
PendingShifts := // Filter any shift start/end that has passed&#xD;
FilterData(MapData(ShiftSchedule, ParseTime($val)), ($val &gt;= Now));&#xD;
CountShifts := // Count the number of shift start/end remaining today&#xD;
ArrayLength(PendingShifts);&#xD;
ABORT2 := // If there isno more remaining shift activity today abort&#xD;
If CountShifts = 0 Then Exit() Else "Continue";&#xD;
EvenCount := // Check if there is an even or odd number of shift start/ends&#xD;
CountShifts Mod 2 = 0;&#xD;
EndOfShifts := // Is this the last shift of the day?&#xD;
CountShifts = 1;&#xD;
ShiftChange := // Is it a shift change now?&#xD;
(If (EndOfShifts) Or (EvenCount) Then PendingShifts[1] Else PendingShifts[2]) = Now;&#xD;
ABORT3 := // If it is a shift change output the shift start and end&#xD;
If ShiftChange Then "Continue" Else Exit();&#xD;
ShiftStart := If EndOfShifts Then NoShift Else If (EvenCount) Then PendingShifts[1] Else PendingShifts[2];&#xD;
ShiftEnd := If EndOfShifts Then NoShift Else If (EvenCount) Then PendingShifts[2] Else PendingShifts[3];</ConfigString>
        <VariableMapping>ShiftStart||Shift Start;ShiftEnd||Shift End;</VariableMapping>
      </AFAnalysisRule>
      <AFTimeRule>
        <AFPlugIn>Periodic</AFPlugIn>
        <ConfigString>Frequency=3600;Offset=2700</ConfigString>
      </AFTimeRule>
    </AFAnalysisTemplate>
    <AFAnalysisTemplate>
      <Name>Shift Tracker</Name>
      <Description />
      <OutputTime />
      <GroupID>0</GroupID>
      <CaseTemplate />
      <Target>Shift Pattern (Daily) Schedule</Target>
      <CreateEnabled>false</CreateEnabled>
      <AFAnalysisRule>
        <AFPlugIn>PerformanceEquation</AFPlugIn>
        <ConfigString>ShiftStart := 'Shift Start';&#xD;
ShiftChanges := EventCount(ShiftStart, 't', '*');&#xD;
ShiftTracker := If BadVal(ShiftStart) Or ShiftChanges = 0 Then 0 Else Abs((ShiftChanges Mod 2) -2);</ConfigString>
        <VariableMapping>ShiftTracker||Shift Count;</VariableMapping>
      </AFAnalysisRule>
      <AFTimeRule>
        <AFPlugIn>Natural</AFPlugIn>
        <ConfigString />
      </AFTimeRule>
    </AFAnalysisTemplate>
